{
  "name": "runboard",
  "version": "1.1.0",
  "description": "Local-first CLI for the Runboard technical-leadership maturity framework. Deterministic scoring core, portable AI adapters, no phone-home.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "runboard": "dist/cli.js",
    "runboard-mcp": "dist/mcp.js"
  },
  "files": [
    "dist",
    "rubric",
    "templates",
    "skills",
    "examples",
    "AGENTS.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "mcp:smoke": "node scripts/mcp-smoke.mjs",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build && npm run mcp:smoke"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "commander": "^12.1.0",
    "eta": "^3.5.0",
    "picocolors": "^1.1.1",
    "yaml": "^2.6.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20.17.0",
    "@vitest/coverage-v8": "^2.1.8",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
